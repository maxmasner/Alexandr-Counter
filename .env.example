# Copy this file to `.env` and adjust values per environment.

# --- image / container ---
IMAGE=alexandr-counter-app
IMAGE_TAG=latest
SERVICE_NAME=alexandr-counter-app

# --- app ---
APP_ENV=production
APP_DEBUG=false
COUNTER_FILE=/data/counter.json
HOST_PORT=8000

# --- persistence ---
DATA_PATH=./data

# --- network ---
NETWORK_NAME=proxy
